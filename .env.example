GOOGLE_API_KEY=your_google_api_key_here

# Optional: force Gemini/LangGraph full analysis path
USE_GENAI_ANALYSIS=false

# Optional CORS (comma-separated)
ALLOWED_ORIGINS=

# Live news ingestion
LIVE_NEWS_ENABLED=true
LIVE_NEWS_PROVIDER=newsapi,rss
NEWSAPI_KEY=your_newsapi_key_here
FINNHUB_API_KEY=
FINNHUB_NEWS_CATEGORY=general
NEWS_QUERY=(India OR Indian) AND (NSE OR BSE OR Sensex OR Nifty OR RBI OR SEBI OR earnings OR stocks OR equities OR banks)
LIVE_NEWS_INTERVAL_MINUTES=30
LIVE_NEWS_LOOKBACK_HOURS=24
LIVE_NEWS_PAGE_SIZE=50
LIVE_NEWS_MAX_ARTICLES_PER_RUN=100

# Sector rotation - cycles through different stock sectors each ingestion
USE_SECTOR_ROTATION=true

# India-focused news sources - prioritizes ET, Moneycontrol, Livemint, etc.
USE_INDIA_DOMAINS=true

# RSS feeds from Indian business news (free, unlimited)
RSS_ENABLED=true

# Fast analysis tuning
FAST_NEWS_MAX_AGE_DAYS=30
FAST_NEWS_MAX_CANDIDATES=120
